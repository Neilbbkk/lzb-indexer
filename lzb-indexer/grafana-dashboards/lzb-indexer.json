{
  "title": "LZB Indexer",
  "uid": "lzb-indexer",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scan Rate (blocks/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(scanner_sepolia_blocks_processed_total[30s])", "legendFormat": "sepolia" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 2,
      "title": "Transfer Rate (tx/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(scanner_sepolia_transfers_found_total[30s])", "legendFormat": "sepolia" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 3,
      "title": "Scan Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(scanner_sepolia_scan_duration_seconds_sum[30s]) / rate(scanner_sepolia_scan_duration_seconds_count[30s])",
          "legendFormat": "avg"
        },
        { "expr": "scanner_sepolia_scan_duration_seconds_max", "legendFormat": "max" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 4,
      "title": "Chain Tip vs Scanned",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "scanner_sepolia_chain_tip", "legendFormat": "chain tip" },
        { "expr": "scanner_sepolia_last_block", "legendFormat": "scanned" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Blocks",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 4 },
      "targets": [ { "expr": "scanner_sepolia_blocks_processed_total" } ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Total Transfers",
      "type": "stat",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 4 },
      "targets": [ { "expr": "scanner_sepolia_transfers_found_total" } ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "Blocks Behind",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 4 },
      "targets": [ { "expr": "scanner_sepolia_chain_tip - scanner_sepolia_last_block" } ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ],
  "schemaVersion": 27,
  "version": 3
}